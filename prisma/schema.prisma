generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  name                   String
  password               String?
  avatarUrl              String?
  lastSeenAt             DateTime?
  locale                 String              @default("en")
  plan                   Plan                @default(FREE)
  midtransSubscriptionId String?             @unique
  subscriptionStatus     SubscriptionStatus  @default(INACTIVE)
  bannedAt               DateTime?

  agreedToTermsAt        DateTime?
  heardFrom              String?
  userType               String?
  tourCompletedAt        DateTime?

  resetToken             String?             @unique
  resetTokenExpiresAt    DateTime?
  isAdmin                Boolean             @default(false)
  applications           Application[]
  oauthAccounts          OAuthAccount[]
  memberships            ApplicationMember[]
  sentInvitations        Invitation[]        @relation("InvitedBy")
  transactions           Transaction[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
}

model OAuthAccount {
  id         String   @id @default(cuid())
  provider   String
  providerId String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

model Application {
  id          String              @id @default(cuid())
  name        String
  type        AppType
  description String?             @db.Text
  apiKey          String              @unique
  userId          String
  trelloToken     String?             @db.Text
  trelloBoardId   String?
  trelloBoardName String?
  trelloListId    String?
  trelloListName  String?
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  bugs        BugReport[]
  feedback    Feedback[]
  members     ApplicationMember[]
  invitations Invitation[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId])
}

model ApplicationMember {
  id            String      @id @default(cuid())
  userId        String
  applicationId String
  role          MemberRole
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, applicationId])
  @@index([applicationId])
  @@index([userId])
}

model Invitation {
  id            String           @id @default(cuid())
  email         String
  role          MemberRole       @default(VIEWER)
  token         String           @unique
  status        InvitationStatus @default(PENDING)
  expiresAt     DateTime
  applicationId String
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  invitedById   String
  invitedBy     User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([applicationId])
  @@index([token])
  @@index([email])
}

model BugReport {
  id            String      @id @default(cuid())
  title         String
  description   String      @db.Text
  status        BugStatus   @default(OPEN)
  priority      Priority    @default(MEDIUM)
  appVersion    String?
  deviceInfo    String?
  stackTrace    String?     @db.Text
  reporterEmail String?
  trelloCardUrl String?
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
  @@index([status])
  @@index([priority])
}

model Feedback {
  id            String         @id @default(cuid())
  title         String
  message       String         @db.Text
  type          FeedbackType   @default(GENERAL)
  status        FeedbackStatus @default(NEW)
  rating        Int?
  reporterEmail String?
  appVersion    String?
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([applicationId])
  @@index([status])
  @@index([type])
}

enum MemberRole {
  VIEWER
  EDITOR
  ADMIN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum FeedbackType {
  GENERAL
  SUGGESTION
  COMPLAINT
  COMPLIMENT
}

enum FeedbackStatus {
  NEW
  READ
  ARCHIVED
}

enum AppType {
  WEBSITE
  ANDROID
  IOS
  DESKTOP
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  INACTIVE
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount           Int
  currency         String            @default("usd")
  status           TransactionStatus @default(SUCCEEDED)
  paymentId        String?           @unique
  plan             Plan
  createdAt        DateTime          @default(now())

  @@index([userId])
}

enum TransactionStatus {
  SUCCEEDED
  FAILED
  REFUNDED
}

model PlanConfig {
  id           String   @id
  plan         Plan     @unique
  displayPrice Int
  planKey      String   @default("")
  features     Json
  updatedAt    DateTime @updatedAt
}
