# ─── Database ──────────────────────────────────────────────────────────────────
# MySQL / MariaDB connection string
DATABASE_URL="mysql://root:password@localhost:3306/bug_report_management"

# ─── Authentication ────────────────────────────────────────────────────────────
# JWT signing secret — must be at least 32 random characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# ─── Application URL ───────────────────────────────────────────────────────────
# Public base URL used in email links, OAuth redirects, and OG metadata
# No trailing slash
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Required for session revocation, rate limiting, and caching
# Local:   redis://localhost:6379
# Upstash: rediss://:<password>@<host>:6380
REDIS_URL=""

# ─── SMTP (Email) ──────────────────────────────────────────────────────────────
# Used for: email verification, password reset, invitation, bug status, delete confirmation
# Leave blank to print links to the console instead (dev mode)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BugReport Manager <noreply@example.com>"

# ─── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secret to authenticate calls to /api/cron/* endpoints
# Call with: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="your-cron-secret-here"

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
# https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Object Storage (S3 / S3-compatible) ───────────────────────────────────────
# Used for profile picture uploads
#
# ── IDCloudHost ──────────────────────────────────────────────────────────────
#   1. Log in to https://console.idcloudhost.com/ → Object Storage → Create Bucket
#   2. Set bucket ACL to "Public" (so uploaded objects are publicly readable)
#   3. Go to Access Keys and generate a new key pair
#
# ── AWS S3 ───────────────────────────────────────────────────────────────────
#   Leave AWS_S3_ENDPOINT blank. IAM permissions needed:
#   s3:PutObject, s3:DeleteObject on arn:aws:s3:::YOUR_BUCKET/avatars/*
#   Disable "Block all public access" on the bucket.
#
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="sgp1"
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT="https://is3.cloudhost.id"   # Leave blank for AWS S3
AWS_S3_PUBLIC_URL=""                          # Optional: CDN URL override (CloudFront, etc.)

# ─── Midtrans ──────────────────────────────────────────────────────────────────
# https://dashboard.midtrans.com/settings/config_info
# 1. Copy your Server Key from Settings → Access Keys
# 2. Set up a Payment Notification URL pointing to /api/midtrans/webhook
# 3. Use Sandbox keys for development, Production keys for live
MIDTRANS_SERVER_KEY="SB-Mid-server-..."

# ─── Trello Integration ────────────────────────────────────────────────────────
# https://trello.com/power-ups/admin
# 1. Create a Power-Up (any name) and copy the API key shown on the overview page
# 2. This is the app-level key; user tokens are obtained via the OAuth flow in Integrations
TRELLO_API_KEY=""

# ─── Sentry Error Monitoring ───────────────────────────────────────────────────
# https://sentry.io — create a project and copy the DSN
# Leave blank to disable Sentry
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Auth token for source map uploads during build (create at sentry.io → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=""

# ─── WhatsApp (Enterprise plan contact) ────────────────────────────────────────
# Format: country code + number, no spaces or dashes (e.g. 628123456789)
NEXT_PUBLIC_WHATSAPP_NUMBER="YOUR_WHATSAPP_NUMBER"
