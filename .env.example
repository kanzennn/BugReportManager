DATABASE_URL="mysql://root:password@localhost:3306/bug_report_management"

# Stripe — https://dashboard.stripe.com/apikeys
# 1. Create two recurring products in Stripe Dashboard: Pro ($2/mo) and Business ($10/mo)
# 2. Copy their Price IDs (price_xxx) into the vars below
# 3. Set up a webhook endpoint pointing to /api/stripe/webhook and copy the signing secret
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."      # $2/month price ID
STRIPE_BUSINESS_PRICE_ID="price_..." # $10/month price ID

# WhatsApp redirect for Enterprise plan
# Format: country code + number, no spaces or dashes (e.g. 628123456789)
NEXT_PUBLIC_WHATSAPP_NUMBER="YOUR_WHATSAPP_NUMBER"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# Base URL (used for OAuth redirect URIs and invitation links)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Object Storage — for profile picture uploads
# Supports AWS S3 and any S3-compatible provider (IDCloudHost, DigitalOcean Spaces, MinIO…)
#
# ── IDCloudHost ────────────────────────────────────────────────────────────────
#   1. Log in to https://console.idcloudhost.com/ → Object Storage → Create Bucket
#   2. Set the bucket ACL to "Public" (so uploaded objects are publicly readable)
#   3. Go to Access Keys and generate a new key pair
#   4. Fill in the values below:
#
#   AWS_ACCESS_KEY_ID    = your IDCloudHost access key
#   AWS_SECRET_ACCESS_KEY= your IDCloudHost secret key
#   AWS_REGION           = sgp1   (Singapore) or the region shown in your dashboard
#   AWS_S3_BUCKET        = your bucket name
#   AWS_S3_ENDPOINT      = https://is3.cloudhost.id
#   AWS_S3_PUBLIC_URL    = leave blank (public URL is derived from the endpoint automatically)
#
# ── AWS S3 ─────────────────────────────────────────────────────────────────────
#   Leave AWS_S3_ENDPOINT blank. IAM permissions needed:
#   s3:PutObject, s3:DeleteObject on arn:aws:s3:::YOUR_BUCKET/avatars/*
#   Disable "Block all public access" on the bucket.
#
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="sgp1"
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT="https://is3.cloudhost.id"   # Leave blank for AWS S3
AWS_S3_PUBLIC_URL=""                          # Optional: CDN URL override (CloudFront, etc.)

# Email (SMTP) — for invitation emails
# Leave blank to log invitation links to the console instead
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BugReport Manager <noreply@example.com>"